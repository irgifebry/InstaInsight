    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.9",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
